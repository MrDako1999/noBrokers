# Backend API base URL. In dev, leave blank to use the Vite proxy.
# In production, point this at your deployed backend (no trailing slash).
VITE_API_URL=

# Google Maps API key — used by:
#   - the address autocomplete + pin-drop on the "List a property" form
#   - the split-pane browse map (/buy and /rent) with price-bubble markers,
#     "search as I move", and the polygon "Draw" tool
#
# Required APIs: Maps JavaScript API, Places API, Geocoding API. The Drawing
# library ships with Maps JS — no separate enable step needed.
# Restrict the key to your Vercel domain(s) and localhost.
VITE_GOOGLE_MAPS_API_KEY=

# Pusher Channels (chat realtime). Get these from the Pusher dashboard.
# Only the public key + cluster are exposed to the browser; the
# corresponding PUSHER_APP_ID and PUSHER_SECRET stay server-side in
# backend/.env (never commit them).
VITE_PUSHER_KEY=
VITE_PUSHER_CLUSTER=
