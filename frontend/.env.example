# Backend API base URL. In dev, leave blank to use the Vite proxy.
# In production, point this at your deployed backend (no trailing slash).
VITE_API_URL=

# Google Maps API key — used by the address autocomplete + map picker on
# the "List a property" form (and any future map view). The key must have
# Maps JavaScript API, Places API, and Geocoding API enabled. Restrict it
# to your Vercel domain(s) and localhost.
VITE_GOOGLE_MAPS_API_KEY=
