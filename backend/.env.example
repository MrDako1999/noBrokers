# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/nobrokers

# JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Cloudflare R2 (S3-compatible object storage for listing images & KYC docs)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=nobrokers-listings
# Public base URL — either the R2.dev subdomain or your custom domain.
# No trailing slash. Example: https://pub-xxxxxxxx.r2.dev
R2_PUBLIC_BASE_URL=

# Frontend URL (for CORS + email links)
CLIENT_URL=http://localhost:5173

# Optional: comma-separated list of additional allowed origins
EXTRA_ALLOWED_ORIGINS=

# Server
PORT=5001
NODE_ENV=development

# Local dev only: POST /login with any registered email + this password skips
# the real bcrypt check (impersonates that user). Unused if unset.
# honoured when NODE_ENV=development, or set ENABLE_LOGIN_BYPASS=true (avoid in prod).
# LOGIN_BYPASS_PASSWORD=
# ENABLE_LOGIN_BYPASS=false

# Seed admin (only used by `npm run seed`)
SEED_ADMIN_EMAIL=admin@nobrokers.my
SEED_ADMIN_PASSWORD=changeme123
SEED_ADMIN_NAME=noBrokers Admin

# Pusher Channels (chat realtime). Grab these from the Pusher dashboard.
# The frontend separately needs VITE_PUSHER_KEY and VITE_PUSHER_CLUSTER
# (same key + cluster, no secret).
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap1
